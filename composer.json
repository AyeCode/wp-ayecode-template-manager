{
  "name": "ayecode/wp-ayecode-template-manager",
  "version": "3.0.2-beta",
  "description": "Centralized template management system for AyeCode WordPress plugins",
  "type": "library",
  "license": "GPL-2.0-or-later",
  "homepage": "https://github.com/AyeCode/wp-ayecode-template-manager",
  "authors": [
    {
      "name": "AyeCode Ltd",
      "email": "support@ayecode.io",
      "homepage": "https://ayecode.io"
    }
  ],
  "require": {
    "php": ">=7.4"
  },
  "autoload": {
    "files": [
      "wp-ayecode-template-manager.php"
    ]
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
